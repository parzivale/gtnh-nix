<?xml version="1.0" encoding="UTF-8"?>
<config>
    <!-- Database section -->
    <database type="sqlite">
        <host>localhost</host>
        <port>5432</port>
        <enabled>true</enabled>
    </database>

    <!-- Logging configuration -->
    <logging>
        <level>INFO</level>
        <!-- File output settings -->
        <file path="/var/log/app.log">
            <rotate>true</rotate>
            <maxSize>10485760</maxSize>
        </file>
    </logging>

    <empty />
</config>
